from datetime import datetime, timedelta
from models import session, User, Video

class CreditManager:
    @staticmethod
    def initialize_lesson(user_id, video_id):
        user = session.query(User).filter_by(id=user_id).first()
        if user.credits < 10:
            return False, "Yetersiz kredi."
        user.credits -= 10
        session.commit()
        return True, "Ders başlatıldı."

    @staticmethod
    def finalize_lesson(user_id, video_id, passed_quiz=False):
        user = session.query(User).filter_by(id=user_id).first()
        video = session.query(Video).filter_by(id=video_id).first()
        instructor = session.query(User).filter_by(id=video.owner_id).first()

        refund = 5 if passed_quiz else 2
        user.credits += refund
        instructor.credits += (10 - refund)
        session.commit()
        return {"refund": refund, "new_balance": user.credits}
